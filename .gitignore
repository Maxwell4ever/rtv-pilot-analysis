output/figures/
output/tables/
output/report/

# Logs are machine-specific
output/logs/

# Processed data (regenerated by pipeline)
data/processed/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor swap files
*.swp
*~
